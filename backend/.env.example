# ============================================================
# AcadWorld Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PLATFORM_NAME=AcadWorld

# ============================================================
# Email Configuration
# ============================================================
# Development (console — prints to terminal, no SMTP needed):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production — GoDaddy (Microsoft 365 SMTP):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@acadworld.com
EMAIL_HOST_PASSWORD=your-godaddy-email-password

# Gmail (App Password required — not your account password):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password

# Mailtrap (https://mailtrap.io — free sandbox for testing HTML emails locally):
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<mailtrap-username>
# EMAIL_HOST_PASSWORD=<mailtrap-password>

# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=<sendgrid-api-key>

DEFAULT_FROM_EMAIL=AcadWorld <info@acadworld.com>

# Set to True to send real emails even when DEBUG=True
SEND_EMAILS_IN_DEBUG=True

# Email address that receives Super Admin notifications (new institutions, etc.)
SUPER_ADMIN_EMAIL=info@acadworld.com

# ============================================================
# Cloudflare R2 Storage (S3-compatible) — leave empty for local storage
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acadworld-media
R2_PUBLIC_URL=

# ============================================================
# Google OAuth 2.0
# ============================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Web application type → Authorized redirect URIs:
#   http://localhost:8000/api/auth/google/callback/
#   https://acadworld.com/api/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
