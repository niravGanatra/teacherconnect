# ============================================================
# AcadWorld Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PLATFORM_NAME=AcadWorld

# ============================================================
# Email Configuration
# ============================================================
# Development (console — prints to terminal, no SMTP needed):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production (SMTP — e.g. Mailtrap for testing, SendGrid/Gmail for real):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Mailtrap (https://mailtrap.io — free inbox for testing HTML emails):
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<mailtrap-username>
# EMAIL_HOST_PASSWORD=<mailtrap-password>

# Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password   # Use an App Password, not your account password

# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=<sendgrid-api-key>

DEFAULT_FROM_EMAIL=AcadWorld <noreply@acadworld.com>

# Set to True to send real emails even when DEBUG=True
SEND_EMAILS_IN_DEBUG=True

# Email address that receives Super Admin notifications (new institutions, etc.)
SUPER_ADMIN_EMAIL=admin@yourplatform.com

# ============================================================
# Cloudflare R2 Storage (S3-compatible) — leave empty for local storage
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acadworld-media
R2_PUBLIC_URL=

# ============================================================
# Google OAuth 2.0
# ============================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Web application type → Authorized redirect URIs:
#   http://localhost:8000/api/auth/google/callback/
#   https://acadworld.com/api/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
