# ============================================================
# AcadWorld Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PLATFORM_NAME=AcadWorld

# ============================================================
# Email Configuration — Resend (django-anymail)
# ============================================================
# Production: set RESEND_API_KEY — all other email vars are ignored
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
DEFAULT_FROM_EMAIL=AcadWorld <info@acadworld.com>

# Development: if RESEND_API_KEY is not set, emails print to console automatically
# To force console backend locally even if key is set:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Set to True to send real emails even when DEBUG=True
SEND_EMAILS_IN_DEBUG=True

# Email address that receives Super Admin notifications (new institutions, etc.)
SUPER_ADMIN_EMAIL=info@acadworld.com

# ============================================================
# Cloudflare R2 Storage (S3-compatible) — leave empty for local storage
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acadworld-media
R2_PUBLIC_URL=

# ============================================================
# Google OAuth 2.0
# ============================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Web application type → Authorized redirect URIs:
#   http://localhost:8000/api/auth/google/callback/
#   https://acadworld.com/api/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
